[Unit]
Description=Kakao Bot Webhook Server
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/kakao-bot-oci
ExecStart=/home/ubuntu/kakao-bot-oci/.venv/bin/gunicorn -w 2 -b 127.0.0.1:5000 bot_server:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
